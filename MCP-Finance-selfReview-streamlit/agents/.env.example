# =============================================================================
# agents/.env.example  —  API Key Configuration
# =============================================================================
# Copy this file to agents/.env and fill in the key for your chosen provider.
# Set the provider in agent_config.yaml under models.provider.
# =============================================================================

# -----------------------------------------------------------------------------
# Mistral AI  (provider: "mistral" in agent_config.yaml)
# Get your key at: https://console.mistral.ai/api-keys
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=your_mistral_api_key_here

# -----------------------------------------------------------------------------
# Google Gemini  (provider: "gemini" in agent_config.yaml)
# Get your key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# DeepSeek  (provider: "deepseek" in agent_config.yaml)
# Get your key at: https://platform.deepseek.com/api_keys
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# -----------------------------------------------------------------------------
# Groq  (provider: "groq" in agent_config.yaml)  — FREE tier available
# Get your key at: https://console.groq.com/keys
# Recommended models: llama-3.3-70b-versatile (large), llama-3.1-8b-instant (small)
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
