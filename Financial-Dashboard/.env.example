# =============================================================================
# .env.example — Copy this to .env and fill in your API keys
# =============================================================================
# Set the key matching your chosen models.provider in agent_config.yaml
# Only one key is required at a time.

MISTRAL_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
DEEPSEEK_API_KEY=

# ---------------------------------------------------------------
# Google Workspace OAuth2 credentials (required for Gmail access)
# Run:  python scripts/get_google_token.py
# to generate these values from your credentials.json
# ---------------------------------------------------------------
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=
